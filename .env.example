# ─── Firebase ─────────────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Web app → Config
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
VITE_FIREBASE_MESSAGING_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# ─── Claude AI (for Home screen Sort button) ──────────────────────────────────
# Get this from: https://console.anthropic.com → API Keys
VITE_CLAUDE_API_KEY=YOUR_CLAUDE_API_KEY
